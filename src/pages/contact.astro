---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import FAQSection from '../components/FAQSection.astro';

const faqs = [
  { q: "How quickly can you respond to a booking request?", a: "We aim to respond to all enquiries within 24 hours. During peak season (May–September), we may book up quickly, so we recommend getting in touch at least a week in advance. Maintenance plan members get priority scheduling." },
  { q: "Can you do an emergency or urgent hull clean?", a: "We'll always do our best to accommodate urgent requests — whether it's a race preparation, an unexpected surveyor visit, or a pre-sale requirement. Contact us directly by phone for same-week availability and we'll fit you in if we possibly can." },
  { q: "What information do you need to give me a quote?", a: "Just three things: your boat's length (LOA), which marina or mooring you're at, and roughly when you'd like the service. If you know your hull material and when it was last antifouled, that helps us select the right brush — but it's not essential for a quote." },
];
---
<ServiceLayout
  title="Contact & Booking"
  description="Book a hull clean, hull inspection, or get in touch with HullSafe. Serving Brixham, Torquay, and Dartmouth marinas across South Devon."
  heroTitle="Get in Touch"
  heroSubtitle="Book a clean, book an inspection, or send us a question. We typically respond within 24 hours."
  heroImage="/images/locations/brixham-harbour.png"
  heroBadge="Book Today"
  ctaText=""
  ctaLink=""
>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Form -->
        <div class="forms-column">
          <div class="form-card" id="contact-form">
            <div class="form-card__header">
              <h2>Send Us a Message</h2>
              <p>Whether you'd like to book a service, get a quote, or just ask a question — drop us a line and we'll get back to you within 24 hours.</p>
            </div>
            <form action="https://formsubmit.co/hello@hullsafe.co.uk" method="POST" class="booking-form">
              <!-- FormSubmit config -->
              <input type="hidden" name="_subject" value="New enquiry from HullSafe website" />
              <input type="hidden" name="_next" value="https://hullsafe.co.uk/contact?submitted=true" />
              <input type="hidden" name="_captcha" value="true" />
              <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

              <div class="form-row">
                <div class="form-group">
                  <label for="contact-name">Name <span class="required">*</span></label>
                  <input type="text" id="contact-name" name="name" required placeholder="Your name" />
                </div>
                <div class="form-group">
                  <label for="contact-email">Email <span class="required">*</span></label>
                  <input type="email" id="contact-email" name="email" required placeholder="you@example.com" />
                </div>
              </div>
              <div class="form-group">
                <label for="contact-phone">Phone <span class="optional">(optional)</span></label>
                <input type="tel" id="contact-phone" name="phone" placeholder="07XXX XXX XXX" />
              </div>
              <div class="form-group">
                <label for="contact-message">Message <span class="required">*</span></label>
                <textarea id="contact-message" name="message" required rows="5" placeholder="Tell us about your boat, which service you're interested in, or ask us anything..."></textarea>
              </div>
              <button type="submit" class="btn btn--primary btn--large" style="width:100%">Send Message</button>
            </form>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="contact-sidebar">
          <div class="contact-info">
            <h3>Contact Information</h3>
            <div class="contact-item">
              <strong>📧 Email</strong>
              <a href="mailto:hello@hullsafe.co.uk">hello@hullsafe.co.uk</a>
            </div>
            <div class="contact-item">
              <strong>📱 Phone</strong>
              <a href="tel:+447000000000">07XXX XXX XXX</a>
            </div>
            <div class="contact-item">
              <strong>📍 Based in</strong>
              <span>Brixham, South Devon</span>
            </div>
          </div>

          <div class="contact-info">
            <h3>Service Area</h3>
            <ul class="service-areas">
              <li><a href="/locations/brixham">Brixham Marina (MDL)</a></li>
              <li><a href="/locations/torquay">Torquay Marina (MDL)</a></li>
              <li><a href="/locations/dartmouth">Darthaven Marina (Dartmouth)</a></li>
            </ul>
          </div>

          <div class="contact-info">
            <h3>Quick Pricing</h3>
            <div class="quick-price">
              <span>Hull Cleaning</span>
              <strong>£15/m</strong>
            </div>
            <div class="quick-price">
              <span>Hull Inspection</span>
              <strong>£10/m</strong>
            </div>
            <a href="/pricing" class="btn btn--outline btn--small" style="width:100%;margin-top:var(--space-md)">Full Pricing →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <FAQSection faqs={faqs} />

</ServiceLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 2fr 1fr; gap: var(--space-3xl); align-items: start; }
  @media (max-width: 1024px) { .contact-grid { grid-template-columns: 1fr; } }

  .form-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    margin-bottom: var(--space-2xl);
  }

  .form-card__header {
    padding: var(--space-xl);
    border-bottom: 1px solid var(--surface-alt);
    border-left: 4px solid var(--accent);
  }

  .form-card__header h2 { font-size: 1.25rem; margin-bottom: var(--space-xs); }
  .form-card__header p { color: var(--text-light); font-size: 0.9rem; margin: 0; }

  .booking-form { padding: var(--space-xl); }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
  @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }

  .required { color: var(--accent); font-weight: 600; }
  .optional { color: var(--text-muted); font-weight: 400; font-size: 0.85em; }


  /* Sidebar */
  .contact-sidebar { position: sticky; top: calc(var(--header-height) + var(--space-lg)); }

  .contact-info {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .contact-info h3 {
    font-size: 1rem;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--surface-alt);
  }

  .contact-item {
    margin-bottom: var(--space-md);
  }

  .contact-item strong {
    display: block;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2px;
  }

  .contact-item a,
  .contact-item span {
    font-size: 0.95rem;
    color: var(--text);
  }

  .service-areas {
    list-style: none;
  }

  .service-areas li {
    padding: var(--space-sm) 0;
  }

  .service-areas a {
    color: var(--accent);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .quick-price {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .quick-price span { color: var(--text-light); font-size: 0.9rem; }
  .quick-price strong { color: var(--primary); font-size: 1.1rem; }
</style>
