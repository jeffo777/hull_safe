---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import services from '../../data/services.json';
import pricing from '../../data/pricing.json';

const service = services.services[0]; // Hull Cleaning
const cleaningPricing = pricing.services.hullCleaning;
---
<ServiceLayout
  title="Hull Cleaning"
  description="Professional robotic hull cleaning across South Devon. Certified brushes preserve your antifouling while removing barnacles, algae, and biofilm. From £15/metre."
  heroTitle="Robotic Hull Cleaning"
  heroSubtitle="Your hull cleaned in the water — no lift-out, no divers, no damage to your antifouling. Just a robot and results."
  heroImage="/images/keelcrab/keelcrab-maintenance.jpg"
  heroBadge="From £15 per metre"
  ctaText="Book a Clean"
>

  <!-- Benefits -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Why Choose Robotic Hull Cleaning?</h2>
        <p class="section__subtitle">Our Keelcrab Pro delivers a superior clean compared to traditional methods — and your boat stays in the water.</p>
      </div>
      <div class="grid grid--4">
        {service.benefits.map((benefit) => (
          <div class="card">
            <h3 class="card__title">{benefit.title}</h3>
            <p class="card__text">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>How It Works</h2>
      </div>
      <div class="process-steps">
        {service.steps.map((step, i) => (
          <div class="process-step">
            <div class="process-step__number">{i + 1}</div>
            <div class="process-step__content">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section">
    <div class="container">
      <div class="included-grid">
        <div class="included-content">
          <h2>What's Included in Every Clean</h2>
          <ul class="included-list">
            {cleaningPricing.includes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <div class="included-price">
            <span class="included-price__amount">£{cleaningPricing.pricePerMetre}</span>
            <span class="included-price__unit">per metre</span>
            <span class="included-price__min">Minimum charge: £{cleaningPricing.minimumCharge}</span>
          </div>
          <a href="/pricing" class="btn btn--primary">View Full Pricing</a>
        </div>
        <div class="included-times">
          <h3>Estimated Cleaning Times</h3>
          <div class="time-cards">
            {service.cleaningTimes.map((ct) => (
              <div class="time-card">
                <span class="time-card__length">{ct.length}</span>
                <span class="time-card__time">{ct.time}</span>
              </div>
            ))}
          </div>
          <h3>Hull Coverage</h3>
          <div class="coverage-stats">
            <div class="coverage-stat">
              <span class="coverage-stat__value">{service.coverageStats.displacement.coverage}</span>
              <span class="coverage-stat__label">{service.coverageStats.displacement.label}</span>
            </div>
            <div class="coverage-stat">
              <span class="coverage-stat__value">{service.coverageStats.planing.coverage}</span>
              <span class="coverage-stat__label">{service.coverageStats.planing.label}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video -->
  <section class="section section--dark">
    <div class="container">
      <div class="section__header">
        <h2>See It In Action</h2>
        <p class="section__subtitle">Watch our Keelcrab Pro cleaning a hull underwater — real footage, real results.</p>
      </div>
      <div class="video-section">
        <div class="video-embed">
          <iframe src="https://www.youtube.com/embed/xJHd6HrKWjY" title="Underwater ROV Cleaning a Boat Hull" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Locations -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Available Across South Devon</h2>
      </div>
      <div class="grid grid--3">
        <a href="/locations/brixham/hull-cleaning" class="card location-link">
          <h3 class="card__title">Brixham</h3>
          <p class="card__text">Hull cleaning at MDL Brixham Marina — 485 berths, vessels up to 18m.</p>
          <span class="card__cta">Learn more →</span>
        </a>
        <a href="/locations/torquay/hull-cleaning" class="card location-link">
          <h3 class="card__title">Torquay</h3>
          <p class="card__text">Hull cleaning at MDL Torquay Marina — 440 berths, vessels up to 30m.</p>
          <span class="card__cta">Learn more →</span>
        </a>
        <a href="/locations/dartmouth/hull-cleaning" class="card location-link">
          <h3 class="card__title">Dartmouth</h3>
          <p class="card__text">Hull cleaning at Darthaven Marina — 270 berths, vessels up to 21.3m.</p>
          <span class="card__cta">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

</ServiceLayout>

<style>
  .process-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
    max-width: 900px;
    margin: 0 auto;
  }

  .process-step {
    text-align: center;
  }

  .process-step__number {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--text-on-accent);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-md);
  }

  .process-step h3 { font-size: 1.1rem; margin-bottom: var(--space-sm); }
  .process-step p { color: var(--text-light); font-size: 0.9rem; }

  @media (max-width: 768px) {
    .process-steps { grid-template-columns: 1fr; }
  }

  .included-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  @media (max-width: 768px) {
    .included-grid { grid-template-columns: 1fr; }
  }

  .included-list {
    list-style: none;
    margin: var(--space-xl) 0;
  }

  .included-list li {
    padding: var(--space-sm) 0;
    font-size: 1rem;
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .included-list li::before {
    content: '✓';
    color: var(--success);
    font-weight: 700;
    flex-shrink: 0;
  }

  .included-price {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .included-price__amount {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: var(--primary);
  }

  .included-price__unit {
    display: block;
    color: var(--text-light);
    font-size: 1rem;
  }

  .included-price__min {
    display: block;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: var(--space-xs);
  }

  .time-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .time-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background: var(--surface);
    border-radius: var(--radius-md);
  }

  .time-card__length { font-weight: 600; color: var(--primary); }
  .time-card__time { font-weight: 600; color: var(--accent); }

  .coverage-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .coverage-stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-md) var(--space-lg);
    background: var(--surface);
    border-radius: var(--radius-md);
  }

  .coverage-stat__value { font-weight: 700; color: var(--success); font-size: 1.1rem; }
  .coverage-stat__label { color: var(--text-light); font-size: 0.9rem; }

  .video-section { max-width: 800px; margin: 0 auto; }

  .location-link {
    text-decoration: none;
    color: var(--text);
  }

  .card__cta {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
    margin-top: var(--space-md);
    display: inline-block;
  }

  .included-times h3 {
    margin-bottom: var(--space-md);
    font-size: 1.1rem;
  }
</style>
