---
import LocationLayout from '../../../layouts/LocationLayout.astro';
import FAQSection from '../../../components/FAQSection.astro';
import locations from '../../../data/locations.json';
import pricing from '../../../data/pricing.json';

const loc = locations.locations[0]; // Brixham

const faqs = [
  { q: "Can you reach all berths in Brixham Marina?", a: "Yes. We can access all pontoon berths within Brixham Marina. For boats in the inner harbour or on visitor berths, we'll arrange access through the marina office. Our Keelcrab Pro system is fully portable, so we can deploy from any pontoon finger." },
  { q: "Does tidal access affect when you can clean at Brixham?", a: "Brixham Marina is a half-tide harbour, meaning access depends on tidal conditions. We schedule all cleans around the tidal window to ensure full access to your hull. When you book, we'll confirm the best time slot based on the tides for your preferred date." },
  { q: "Do you service boats on swing moorings in Brixham?", a: "Yes, we can service vessels on swing moorings within Brixham harbour, subject to access and weather conditions. We'll bring our equipment alongside by tender if needed. Contact us to discuss logistics for your specific mooring location." },
];
---
<LocationLayout
  title="Hull Cleaning & Inspection in Brixham"
  description="Professional robotic hull cleaning & inspection at Brixham Marina. 485 berths, vessels up to 18m. From £15/metre. Powered by Keelcrab."
  locationName={loc.name}
  locationSlug={loc.slug}
  marina={loc.marina}
  tagline={loc.tagline}
  berths={loc.berths}
  maxVesselLength={loc.maxVesselLength}
  access={loc.access}
  foulingFactors={loc.foulingFactors}
  contentAngle={loc.contentAngle}
  heroImage="/images/locations/brixham-harbour.png"
>

  <!-- About the Marina -->
  <section class="section">
    <div class="container">
      <div class="content-grid">
        <div class="content-main">
          <h2>Hull Care at {loc.marina}</h2>
          <p>{loc.character}</p>
          <p>HullSafe brings professional robotic hull cleaning and inspection directly to Brixham Marina — no need to lift out, no disruption to your schedule, and no risk to your antifouling paint.</p>
          <p>Whether you own a fishing vessel, a cruising yacht, or a sailing dinghy, our Keelcrab Pro robot keeps your hull performing at its best in Torbay's nutrient-rich waters.</p>
        </div>
        <div class="content-sidebar">
          <div class="marina-info">
            <h3>Marina at a Glance</h3>
            <dl>
              <dt>Berths</dt><dd>{loc.berths}</dd>
              <dt>Max Vessel</dt><dd>{loc.maxVesselLength}</dd>
              <dt>Access</dt><dd>{loc.access}</dd>
              <dt>Operator</dt><dd>{loc.operator}</dd>
              <dt>Nearby Yard</dt><dd>{loc.nearbyYard || 'N/A'}</dd>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Fouling Factors -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Why Regular Cleaning Matters in Brixham</h2>
        <p class="section__subtitle">Brixham's unique harbour environment creates specific fouling challenges for boat owners.</p>
      </div>
      <div class="grid grid--2">
        {loc.foulingFactors.map((factor) => (
          <div class="card">
            <h3 class="card__title">{factor.title}</h3>
            <p class="card__text">{factor.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Available -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Our Services in Brixham</h2>
      </div>
      <div class="grid grid--3">
        <a href="/locations/brixham/hull-cleaning" class="card service-link">
          <div class="card__icon">🛥️</div>
          <h3 class="card__title">Hull Cleaning</h3>
          <p class="card__text">Full robotic hull clean from £{pricing.services.hullCleaning.pricePerMetre}/m. HD video report included.</p>
          <span class="card__cta">Learn more →</span>
        </a>
        <a href="/locations/brixham/hull-inspection" class="card service-link">
          <div class="card__icon">🔍</div>
          <h3 class="card__title">Hull Inspection</h3>
          <p class="card__text">Visual condition report from £{pricing.services.hullInspection.pricePerMetre}/m. See below the waterline.</p>
          <span class="card__cta">Learn more →</span>
        </a>
        <a href="/locations/brixham/maintenance-plans" class="card service-link">
          <div class="card__icon">📋</div>
          <h3 class="card__title">Maintenance Plans</h3>
          <p class="card__text">Save up to {pricing.subscriptions.premium.discountPercent}% with a regular cleaning subscription.</p>
          <span class="card__cta">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <FAQSection faqs={faqs} />

</LocationLayout>

<style>
  .content-grid { display: grid; grid-template-columns: 2fr 1fr; gap: var(--space-3xl); align-items: start; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } }

  .content-main p { color: var(--text-light); margin-bottom: var(--space-md); line-height: 1.7; }
  .content-main p:first-of-type { color: var(--text); font-size: 1.05rem; }

  .marina-info {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    position: sticky;
    top: calc(var(--header-height) + var(--space-lg));
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }
  .marina-info h3 { font-size: 1rem; margin-bottom: var(--space-md); color: var(--primary); }
  .marina-info dl { display: grid; grid-template-columns: auto 1fr; gap: var(--space-sm) var(--space-md); }
  .marina-info dt { font-weight: 600; font-size: 0.85rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.03em; }
  .marina-info dd { font-size: 0.9rem; color: var(--text); }

  .service-link { text-decoration: none; color: var(--text); }
  .card__cta { color: var(--accent); font-weight: 600; font-size: 0.9rem; margin-top: var(--space-md); display: inline-block; }
</style>
