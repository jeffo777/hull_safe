---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---
<ServiceLayout
  title="Gallery"
  description="See HullSafe's robotic hull cleaning in action. Before & after photos, underwater GoPro footage, and Keelcrab technology videos."
  heroTitle="Gallery"
  heroSubtitle="See the technology in action — underwater footage, before & after results, and live cleaning demonstrations."
  heroImage="/images/keelcrab/keelcrab-pontoon-setup.jpg"
  heroBadge="Real Results"
  ctaText="Book a Clean"
>

  <!-- Video Gallery -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Watch It Work</h2>
        <p class="section__subtitle">Real footage from Keelcrab operators around the world. This is the exact technology we use at HullSafe.</p>
      </div>
      <div class="video-grid">
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/3Zv9ICgNKrE" title="Keelcrab Pro — Product Showcase" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Keelcrab Pro Showcase</h3>
          <p>Full product overview of the Keelcrab Pro — the technology powering HullSafe.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/xJHd6HrKWjY" title="Underwater ROV Hull Cleaning" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Underwater Cleaning Footage</h3>
          <p>GoPro-style underwater footage of the robot cleaning a yacht hull in real-time.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/npROmO5-H-Q" title="Live Hull Cleaning — Medium Fouling" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Medium Fouling — Live Clean</h3>
          <p>Watch how the nylon brushes tackle medium barnacle and algae growth.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/BizYeYOhmEk" title="Live Hull Cleaning — Light Fouling" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Light Fouling — Maintenance Clean</h3>
          <p>A regular maintenance clean on light biofilm — the kind subscription members see.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/Zk4uF76qge0" title="Controller View — Sailboat Clean" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Operator's View — Sailboat</h3>
          <p>See what the operator sees on the controller screen during a live sailboat clean.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/fTg-_2Qvkr4" title="Keelcrab Live Cleaning — January 2025" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Live Cleaning — Results in Action</h3>
          <p>Recent live footage showing the Keelcrab cleaning a hull in real-time — demonstrating effectiveness on real-world fouling.</p>
        </div>

    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="section section--dark">
    <div class="container">
      <div class="section__header">
        <h2>The Equipment & Team</h2>
        <p class="section__subtitle">Authentic photos of Keelcrab technology and operators at work — the same equipment and process we use at HullSafe.</p>
      </div>
      <div class="photo-grid">
        <div class="photo-card">
          <img src="/images/keelcrab/keelcrab-pontoon-setup.jpg" alt="Keelcrab robot with control unit and screen set up on a marina pontoon" loading="lazy" />
          <p>Complete Keelcrab setup — robot, control unit, and live monitoring screen at the marina</p>
        </div>
        <div class="photo-card">
          <img src="/images/keelcrab/keelcrab-studio-brushes.jpg" alt="Keelcrab robot showing certified brushes and track system alongside the control unit" loading="lazy" />
          <p>A.N.C.C.P certified brushes and precision track system — engineered to clean without damaging antifouling</p>
        </div>
        <div class="photo-card">
          <img src="/images/keelcrab/keelcrab-operator-marina.jpg" alt="Keelcrab operator monitoring a live hull clean from the pontoon with a sailboat behind" loading="lazy" />
          <p>Operator monitoring a live clean from the pontoon — photos and video sent directly to your smartphone</p>
        </div>
        <div class="photo-card">
          <img src="/images/keelcrab/keelcrab-operator-watching.jpg" alt="Operator watching the Keelcrab work underwater from a harbour pontoon" loading="lazy" />
          <p>Calm, professional operation — no divers, no disruption, just results</p>
        </div>
        <div class="photo-card">
          <img src="/images/keelcrab/keelcrab-brush-closeup.jpg" alt="Close-up of Keelcrab cleaning brush mechanism with green rollers" loading="lazy" />
          <p>Close-up of the interchangeable brush system — soft, standard, and heavy-duty options</p>
        </div>
        <div class="photo-card">
          <img src="/images/keelcrab/yacht-clean-hull-result.jpg" alt="Sailing yacht with a visibly clean waterline after Keelcrab service" loading="lazy" />
          <p>The result — a clean waterline, improved performance, and up to 20% fuel savings</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Keelcrab Pro — Close-Up Gallery -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>The Keelcrab Pro — Up Close</h2>
        <p class="section__subtitle">Professional photography of the exact Keelcrab Pro robot, control unit, and interchangeable brush system we use at HullSafe.</p>
      </div>
      <div class="photo-grid photo-grid--light">
        <div class="photo-card photo-card--light">
          <img src="/images/keelcrab/optimised/underwater-keelcrab-action-1.jpg" alt="Keelcrab Pro robot showing HD camera lenses and certified nylon brush tracks" loading="lazy" />
          <p>Keelcrab Pro with dual HD camera lenses and certified nylon brush system</p>
        </div>
        <div class="photo-card photo-card--light">
          <img src="/images/keelcrab/optimised/underwater-keelcrab-cleaning.jpg" alt="Front view of the Keelcrab Pro showing track system and camera housing" loading="lazy" />
          <p>Front view — precision track system designed for smooth hull navigation</p>
        </div>
        <div class="photo-card photo-card--light">
          <img src="/images/keelcrab/optimised/keelcrab-equipment-detail.jpg" alt="Keelcrab Pro robot alongside the Keelcrab ACS control unit with live monitoring screen" loading="lazy" />
          <p>Robot and ACS control unit — the operator's complete remote monitoring system</p>
        </div>
        <div class="photo-card photo-card--light">
          <img src="/images/keelcrab/optimised/keelcrab-brushes-detail.jpg" alt="Close-up of Keelcrab interchangeable A.N.C.C.P certified nylon brush heads" loading="lazy" />
          <p>A.N.C.C.P certified interchangeable brush heads — designed to clean without stripping antifouling</p>
        </div>
        <div class="photo-card photo-card--light">
          <img src="/images/keelcrab/optimised/keelcrab-product-shot.jpg" alt="Keelcrab ACS control unit showing live video screen and remote control ports" loading="lazy" />
          <p>ACS control station — live HD video feed and full remote diagnostics</p>
        </div>
        <div class="photo-card photo-card--light">
          <img src="/images/keelcrab/optimised/marina-harbour-scene.jpg" alt="Keelcrab Pro portable carry case with KEELCRAB branding" loading="lazy" />
          <p>Professional carry case — the complete Keelcrab Pro system is fully portable to any marina</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Before/After Placeholder -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Before & After</h2>
        <p class="section__subtitle">Real results from robotic hull cleaning — coming soon with local South Devon footage.</p>
      </div>
      <div class="coming-soon">
        <div class="coming-soon__icon">📸</div>
        <h3>Local Gallery Coming Soon</h3>
        <p>We're building our local gallery with real before & after photos from Brixham, Torquay, and Dartmouth. In the meantime, watch the videos above to see the technology in action.</p>
        <a href="/contact" class="btn btn--primary">Book a Clean & Be Featured</a>
      </div>
    </div>
  </section>

</ServiceLayout>

<style>
  .video-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .video-grid { grid-template-columns: 1fr; }
  }

  .video-card h3 {
    font-size: 1.1rem;
    margin: var(--space-md) 0 var(--space-sm);
  }

  .video-card p {
    color: var(--text-light);
    font-size: 0.9rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  @media (max-width: 768px) {
    .photo-grid { grid-template-columns: 1fr; }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .photo-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .photo-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-sm);
  }

  .photo-card p {
    color: rgba(255,255,255,0.7);
    font-size: 0.85rem;
    line-height: 1.4;
  }

  /* Light-background variant for product shots */
  .photo-card--light {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all var(--transition-base);
  }

  .photo-card--light:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .photo-card--light img {
    height: 240px;
    object-fit: contain;
    background: var(--surface);
    border-radius: var(--radius-md);
  }

  .photo-card--light p {
    color: var(--text-light);
    margin-top: var(--space-sm);
  }

  .coming-soon {
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
    padding: var(--space-3xl) 0;
  }

  .coming-soon__icon {
    font-size: 3rem;
    margin-bottom: var(--space-lg);
  }

  .coming-soon h3 {
    margin-bottom: var(--space-md);
  }

  .coming-soon p {
    color: var(--text-light);
    margin-bottom: var(--space-xl);
  }
</style>
