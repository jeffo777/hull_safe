---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---
<ServiceLayout
  title="Gallery"
  description="See HullSafe's robotic hull cleaning in action. Before & after photos, underwater GoPro footage, and Keelcrab technology videos."
  heroTitle="Gallery"
  heroSubtitle="See the technology in action — underwater footage, before & after results, and live cleaning demonstrations."
  heroBadge="Real Results"
  ctaText="Book a Clean"
>

  <!-- Video Gallery -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Watch It Work</h2>
        <p class="section__subtitle">Real footage from Keelcrab operators around the world. This is the exact technology we use at HullSafe.</p>
      </div>
      <div class="video-grid">
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/3Zv9ICgNKrE" title="Keelcrab Pro — Product Showcase" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Keelcrab Pro Showcase</h3>
          <p>Full product overview of the Keelcrab Pro — the technology powering HullSafe.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/xJHd6HrKWjY" title="Underwater ROV Hull Cleaning" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Underwater Cleaning Footage</h3>
          <p>GoPro-style underwater footage of the robot cleaning a yacht hull in real-time.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/npROmO5-H-Q" title="Live Hull Cleaning — Medium Fouling" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Medium Fouling — Live Clean</h3>
          <p>Watch how the nylon brushes tackle medium barnacle and algae growth.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/BizYeYOhmEk" title="Live Hull Cleaning — Light Fouling" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Light Fouling — Maintenance Clean</h3>
          <p>A regular maintenance clean on light biofilm — the kind subscription members see.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/Zk4uF76qge0" title="Controller View — Sailboat Clean" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>Operator's View — Sailboat</h3>
          <p>See what the operator sees on the controller screen during a live sailboat clean.</p>
        </div>
        <div class="video-card">
          <div class="video-embed">
            <iframe src="https://www.youtube.com/embed/phXpeb2DQlg" title="How Keelcrab Works — Tutorial" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <h3>How It Works — Tutorial</h3>
          <p>Step-by-step walkthrough of how the Keelcrab system operates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Before/After Placeholder -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Before & After</h2>
        <p class="section__subtitle">Real results from robotic hull cleaning — coming soon with local South Devon footage.</p>
      </div>
      <div class="coming-soon">
        <div class="coming-soon__icon">📸</div>
        <h3>Local Gallery Coming Soon</h3>
        <p>We're building our local gallery with real before & after photos from Brixham, Torquay, and Dartmouth. In the meantime, watch the videos above to see the technology in action.</p>
        <a href="/contact" class="btn btn--primary">Book a Clean & Be Featured</a>
      </div>
    </div>
  </section>

</ServiceLayout>

<style>
  .video-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .video-grid { grid-template-columns: 1fr; }
  }

  .video-card h3 {
    font-size: 1.1rem;
    margin: var(--space-md) 0 var(--space-sm);
  }

  .video-card p {
    color: var(--text-light);
    font-size: 0.9rem;
  }

  .coming-soon {
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
    padding: var(--space-3xl) 0;
  }

  .coming-soon__icon {
    font-size: 3rem;
    margin-bottom: var(--space-lg);
  }

  .coming-soon h3 {
    margin-bottom: var(--space-md);
  }

  .coming-soon p {
    color: var(--text-light);
    margin-bottom: var(--space-xl);
  }
</style>
