---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import pricing from '../data/pricing.json';
import services from '../data/services.json';
import locations from '../data/locations.json';

const title = "Robotic Hull Cleaning & Inspection — Brixham, Torquay, Dartmouth";
const description = "Professional robotic hull cleaning & inspection across South Devon. Powered by Keelcrab technology. From £15/metre. Save up to 20% with a maintenance plan.";

const faqs = [
  { q: "What is robotic hull cleaning and how does it work?", a: "Robotic hull cleaning uses an underwater robot — our Keelcrab Pro — to clean your boat's hull while it stays in the water. The robot is deployed from the pontoon, attaches to your hull, and moves across the surface using A.N.C.C.P. certified nylon brushes to remove barnacles, algae, and biofilm. An onboard HD camera provides live footage throughout the clean." },
  { q: "Do I need to take my boat out of the water for a hull clean?", a: "No — that's the whole point. Our robotic service cleans your hull in-water at your marina berth. No crane, no travel lift, no expensive haul-out fees, and no disruption to your schedule. Your boat stays afloat while we work." },
  { q: "Where does HullSafe operate?", a: "We cover three South Devon marinas: Brixham Marina, Torquay Marina, and Darthaven Marina in Dartmouth. We also service vessels on swing moorings and private pontoons along the River Dart." },
  { q: "How is robotic cleaning different from using a diver?", a: "Robotic cleaning eliminates the need for commercial dive teams and associated HSE risks — there are no divers in the water at any point. The robot delivers consistent, systematic coverage with certified brushes that won't damage your antifouling, plus HD video proof of the entire clean sent to your phone." },
  { q: "Can I watch the cleaning process?", a: "Yes. The Keelcrab's onboard HD camera feeds live footage to the operator's screen, and you're welcome to watch from the pontoon. After the clean, the full video footage is delivered directly to your smartphone so you can see exactly what was done." },
];
---
<BaseLayout title={title} description={description}>

  <!-- ===== HERO ===== -->
  <section class="hero" id="hero">
    <div class="hero__overlay"></div>
    <div class="container hero__content">
      <div class="hero__text">
        <span class="badge badge--accent animate-in">Powered by Keelcrab Technology</span>
        <h1 class="hero__title animate-in animate-delay-1">Safe for your Hull.<br />Safe for the Sea.</h1>
        <p class="hero__subtitle animate-in animate-delay-2">Professional robotic hull cleaning & inspection across Brixham, Torquay & Dartmouth. Eco-friendly. Camera-documented. No lift-out required.</p>
        <div class="hero__cta animate-in animate-delay-3">
          <a href="/contact" class="btn btn--primary btn--large">Get a Free Quote</a>
          <a href="/gallery" class="btn btn--secondary btn--large">See It In Action</a>
        </div>
        <div class="hero__stats animate-in animate-delay-4">
          <div class="hero__stat">
            <span class="hero__stat-value">£15</span>
            <span class="hero__stat-label">per metre</span>
          </div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat">
            <span class="hero__stat-value">1-2hrs</span>
            <span class="hero__stat-label">typical clean</span>
          </div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat">
            <span class="hero__stat-value">HD</span>
            <span class="hero__stat-label">video report</span>
          </div>
        </div>
      </div>
      <div class="hero__image animate-in animate-delay-2">
        <img src="/images/hero/yacht-hero-left.png" alt="Premium yacht powering through South Devon waters" />
      </div>
    </div>
  </section>

  <!-- ===== QUAD-SAFE ===== -->
  <section class="section" id="quad-safe">
    <div class="container">
      <div class="section__header">
        <span class="badge badge--primary">The Quad-Safe Promise</span>
        <h2>Four Pillars of Protection</h2>
        <p class="section__subtitle">Every HullSafe service delivers on all four — because cutting corners below the waterline is never an option.</p>
      </div>
      <div class="grid grid--4">
        {services.quadSafe.map((pillar, i) => (
          <div class={`card animate-in animate-delay-${i + 1}`}>
            <div class="card__icon">{pillar.icon}</div>
            <h3 class="card__title">{pillar.pillar}</h3>
            <p class="card__text">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="section section--dark" id="how-it-works">
    <div class="container">
      <div class="section__header">
        <span class="badge badge--accent">Simple Process</span>
        <h2>How It Works</h2>
        <p class="section__subtitle">From booking to report — your hull clean is done in three easy steps.</p>
      </div>
      <div class="steps">
        {services.services[0].steps.map((step, i) => (
          <div class="step">
            <div class="step__number">{i + 1}</div>
            <div class="step__content">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="video-section">
        <div class="video-embed">
          <iframe 
            src="https://www.youtube.com/embed/3Zv9ICgNKrE" 
            title="Keelcrab Pro — Product Showcase" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMPARISON TABLE ===== -->
  <section class="section" id="comparison">
    <div class="container">
      <div class="section__header">
        <span class="badge badge--primary">Why Choose Robotic</span>
        <h2>How We Compare</h2>
        <p class="section__subtitle">See how robotic hull cleaning stacks up against traditional methods.</p>
      </div>
      <div class="table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              {services.comparison.headers.map((header) => (
                <th>{header}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {services.comparison.rows.map((row) => (
              <tr>
                {row.map((cell, i) => (
                  <td class={i === 0 ? 'comparison-table__feature' : ''}>{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== LOCATIONS ===== -->
  <section class="section section--alt" id="locations">
    <div class="container">
      <div class="section__header">
        <span class="badge badge--primary">Service Areas</span>
        <h2>Serving South Devon's Finest Marinas</h2>
        <p class="section__subtitle">Based in Brixham, covering Torbay and the River Dart — ~1,195 berths across three world-class marinas.</p>
      </div>
      <div class="grid grid--3">
        {locations.locations.map((loc) => (
          <a href={`/locations/${loc.slug}`} class="location-card card">
            <div class="location-card__image">
              <img src={`/images/locations/${loc.slug === 'brixham' ? 'brixham-harbour' : loc.slug === 'torquay' ? 'torquay-marina' : 'dartmouth-river'}.png`} alt={loc.name} loading="lazy" />
            </div>
            <div class="location-card__content">
              <h3>{loc.name}</h3>
              <p class="location-card__tagline">{loc.tagline}</p>
              <div class="location-card__stats">
                <span>{loc.berths} berths</span>
                <span>Up to {loc.maxVesselLength}</span>
              </div>
              <span class="location-card__link">Explore services →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PRICING TEASER ===== -->
  <section class="section section--dark" id="pricing-teaser">
    <div class="container">
      <div class="pricing-teaser">
        <div class="pricing-teaser__content">
          <h2>Transparent, Per-Metre Pricing</h2>
          <p>No hidden fees. No surprises. Just honest pricing based on your boat's length.</p>
          <div class="pricing-teaser__prices">
            <div class="pricing-teaser__price">
              <span class="pricing-teaser__amount">£{pricing.services.hullCleaning.pricePerMetre}</span>
              <span class="pricing-teaser__label">per metre — cleaning</span>
            </div>
            <div class="pricing-teaser__price">
              <span class="pricing-teaser__amount">£{pricing.services.hullInspection.pricePerMetre}</span>
              <span class="pricing-teaser__label">per metre — inspection</span>
            </div>
          </div>
          <div class="pricing-teaser__sub">
            <span class="badge badge--accent">Save up to {pricing.subscriptions.premium.discountPercent}%</span>
            <span>with a maintenance plan</span>
          </div>
        </div>
        <div class="pricing-teaser__cta">
          <a href="/pricing" class="btn btn--primary btn--large">View Full Pricing</a>
          <a href="/services/maintenance-plans" class="btn btn--secondary">See Maintenance Plans</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIAL ===== -->
  <section class="section" id="testimonials">
    <div class="container">
      <div class="section__header">
        <span class="badge badge--primary">Trusted Technology</span>
        <h2>What Operators Say</h2>
      </div>
      <div class="testimonial">
        <blockquote class="testimonial__quote">
          "I truly believe that Keelcrab will revolutionize the way we understand hull maintenance, not only by its performance standards but by taking care of the marine environment."
        </blockquote>
        <cite class="testimonial__author">
          <strong>Richard Court</strong>
          <span>Keelcleaners Poole, UK</span>
        </cite>
      </div>
      <div class="trust-badges-row">
        <a href="https://keelcrab.com" target="_blank" rel="noopener noreferrer" class="trust-badge-card animate-in">
          <img src="/images/keelcrab/keelcrab-point-logo-tr.png" alt="Keelcrab Point Logo" width="80" height="80" loading="lazy" />
          <div class="trust-badge-card__text">
            <span class="trust-badge-card__title">Authorised Keelcrab Point</span>
            <span class="trust-badge-card__subtitle">South Devon's certified operator</span>
          </div>
        </a>
        <a href="/docs/anccp-certificate.pdf" target="_blank" rel="noopener noreferrer" class="trust-badge-card animate-in animate-delay-1">
          <div class="anccp-badge-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" fill="var(--accent)" opacity="0.15"/>
              <path d="M12 2L3 7v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" stroke="var(--accent)" stroke-width="1.5" fill="none"/>
              <path d="M9 12l2 2 4-4" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="trust-badge-card__text">
            <span class="trust-badge-card__title">A.N.C.C.P. Certified</span>
            <span class="trust-badge-card__subtitle">Safe for antifouling — view certificate</span>
          </div>
        </a>
      </div>
      <div class="trust-stats">
        <div class="trust-stat">
          <span class="trust-stat__value">450+</span>
          <span class="trust-stat__label">Robots deployed worldwide</span>
        </div>
        <div class="trust-stat">
          <span class="trust-stat__value">75</span>
          <span class="trust-stat__label">Countries reached</span>
        </div>
        <div class="trust-stat">
          <span class="trust-stat__value">250+</span>
          <span class="trust-stat__label">Professional operators</span>
        </div>
        <div class="trust-stat">
          <span class="trust-stat__value">EU</span>
          <span class="trust-stat__label">Horizon 2020 funded R&D</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQs ===== -->
  <FAQSection faqs={faqs} />

  <!-- ===== CTA ===== -->
  <section class="section section--cta" id="cta">
    <div class="container">
      <div class="cta-strip">
        <h2>Ready to See What's Under Your Hull?</h2>
        <p>Book a hull clean or inspection today. Professional, eco-friendly, and camera-documented.</p>
        <div class="cta-strip__buttons">
          <a href="/contact" class="btn btn--primary btn--large">Book a Clean</a>
          <a href="/contact" class="btn btn--outline btn--large">Book an Inspection</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* --- Hero --- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 50%, #1a3a4a 100%);
    overflow: hidden;
    padding-top: var(--header-height);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 30% 50%, rgba(52, 152, 219, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 80%, rgba(245, 166, 35, 0.08) 0%, transparent 50%);
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
    padding: var(--space-4xl) 0;
  }

  @media (max-width: 768px) {
    .hero__content {
      grid-template-columns: 1fr;
      text-align: center;
      padding: var(--space-3xl) var(--space-xl);
    }
  }

  .hero__text {
    text-align: left;
  }

  @media (max-width: 768px) {
    .hero__text { text-align: center; }
  }

  .hero__title {
    color: var(--white);
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
    margin: var(--space-lg) 0;
    letter-spacing: -0.02em;
  }

  .hero__subtitle {
    color: rgba(255, 255, 255, 0.8);
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 520px;
    margin: 0 0 var(--space-2xl);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .hero__subtitle { margin: 0 auto var(--space-2xl); }
  }

  .hero__cta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .hero__cta { justify-content: center; }
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero__stats { justify-content: center; }
  }

  .hero__stat {
    text-align: center;
  }

  .hero__stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--accent);
  }

  .hero__stat-label {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero__stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.2);
  }

  .hero__image {
    position: relative;
  }

  .hero__image img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
  }

  @media (max-width: 768px) {
    .hero__image { display: none; }
  }

  /* --- Steps --- */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }

  .step {
    text-align: center;
  }

  .step__number {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--text-on-accent);
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-lg);
  }

  .step h3 {
    color: var(--white);
    margin-bottom: var(--space-sm);
    font-size: 1.25rem;
  }

  .step p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .steps {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  /* --- Video Section --- */
  .video-section {
    max-width: 800px;
    margin: 0 auto;
  }

  /* --- Table Wrapper --- */
  .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .comparison-table__feature {
    font-weight: 600;
    color: var(--primary);
  }

  /* --- Location Cards --- */
  .location-card {
    text-decoration: none;
    color: var(--text);
    overflow: hidden;
    padding: 0;
  }

  .location-card__image {
    height: 200px;
    overflow: hidden;
  }

  .location-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .location-card:hover .location-card__image img {
    transform: scale(1.05);
  }

  .location-card__content {
    padding: var(--space-xl);
  }

  .location-card__tagline {
    color: var(--text-light);
    font-size: 0.9rem;
    margin-bottom: var(--space-md);
  }

  .location-card__stats {
    display: flex;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .location-card__link {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* --- Pricing Teaser --- */
  .pricing-teaser {
    text-align: center;
  }

  .pricing-teaser h2 {
    color: var(--white);
    margin-bottom: var(--space-md);
  }

  .pricing-teaser p {
    color: var(--text-muted);
    margin-bottom: var(--space-2xl);
  }

  .pricing-teaser__prices {
    display: flex;
    justify-content: center;
    gap: var(--space-3xl);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .pricing-teaser__amount {
    display: block;
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: var(--accent);
  }

  .pricing-teaser__label {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
  }

  .pricing-teaser__sub {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    color: rgba(255, 255, 255, 0.7);
  }

  .pricing-teaser__cta {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* --- Testimonial --- */
  .testimonial {
    max-width: 700px;
    margin: 0 auto var(--space-3xl);
    text-align: center;
  }

  .testimonial__quote {
    font-size: 1.25rem;
    font-style: italic;
    color: var(--text);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
    position: relative;
    padding: 0 var(--space-xl);
  }

  .testimonial__quote::before {
    content: '"';
    font-family: var(--font-heading);
    font-size: 4rem;
    color: var(--accent);
    position: absolute;
    top: -20px;
    left: -10px;
    opacity: 0.3;
  }

  .testimonial__author {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial__author strong {
    color: var(--primary);
    font-size: 1rem;
  }

  .testimonial__author span {
    color: var(--text-light);
    font-size: 0.9rem;
  }

  /* --- Keelcrab Trust Badge --- */
  /* --- Trust Badges Row --- */
  .trust-badges-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    max-width: 700px;
    margin: 0 auto var(--space-3xl);
  }

  @media (min-width: 600px) {
    .trust-badges-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .trust-badge-card {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    background: var(--surface);
    border: 2px solid rgba(245, 166, 35, 0.2);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    box-shadow: var(--shadow-sm);
  }

  .trust-badge-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-glow);
    transform: translateY(-2px);
  }

  .trust-badge-card img {
    width: 50px;
    height: 50px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .anccp-badge-icon {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .trust-badge-card__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-badge-card__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--primary);
    letter-spacing: -0.01em;
  }

  .trust-badge-card__subtitle {
    font-size: 0.8rem;
    color: var(--text-light);
  }



  /* --- Trust Stats --- */
  .trust-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    text-align: center;
    padding: var(--space-2xl);
    background: var(--surface);
    border-radius: var(--radius-lg);
  }

  .trust-stat__value {
    display: block;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: var(--space-xs);
  }

  .trust-stat__label {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  @media (max-width: 768px) {
    .trust-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* --- CTA Strip --- */
  .section--cta {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
  }

  .cta-strip {
    text-align: center;
  }

  .cta-strip h2 {
    color: var(--text-on-accent);
    margin-bottom: var(--space-md);
  }

  .cta-strip p {
    color: rgba(26, 37, 47, 0.8);
    font-size: 1.125rem;
    margin-bottom: var(--space-2xl);
  }

  .cta-strip__buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-strip .btn--outline {
    border-color: var(--primary);
    color: var(--primary);
  }

  .cta-strip .btn--outline:hover {
    background: var(--primary);
    color: var(--white);
  }
