---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const faqs = [
  {
    category: "The Technology",
    questions: [
      { q: "What is a Keelcrab?", a: "Keelcrab is an Italian-engineered underwater robot designed specifically for hull cleaning and inspection. It attaches to your hull using a magnetic system (or vacuum for GRP hulls) and moves across the surface using interchangeable nylon brushes. Our Keelcrab Pro model cleans up to 7m² per minute." },
      { q: "Will it damage my antifouling paint?", a: "No. The Keelcrab uses A.N.C.C.P. certified nylon brushes that are specifically designed to remove fouling (barnacles, algae, biofilm) without damaging your antifouling coating. In fact, regular robotic cleaning can extend your antifoul's useful life by preventing heavy buildup." },
      { q: "What types of hull can you clean?", a: "We clean GRP (fibreglass), steel, aluminium, and wooden hulls. The Keelcrab Pro has interchangeable brush heads — soft brushes for delicate coatings, standard nylon for routine cleaning, and harder brushes for heavy fouling. We'll select the right brush for your hull." },
      { q: "How much of the hull can the robot reach?", a: "On displacement hulls (typical sailing yachts), we achieve 95-97% coverage. On planing or semi-planing hulls (motor boats), coverage is 85-87%. The robot navigates around keels, rudders, and hull features — only very tight recesses may be missed." },
      { q: "What happens to the debris?", a: "All removed fouling is captured in the Keelcrab Bag — a built-in filtration system that prevents debris from entering the water. This makes our service eco-compliant and marina-approved." },
      { q: "What does A.N.C.C.P. certification mean for the brushes?", a: "A.N.C.C.P. (Associazione Nazionale dei Costruttori e dei Commercianti di Pennelli) is the Italian national brushmakers' certification body. Their testing confirms our nylon brushes remove fouling organisms without stripping or damaging hard matrix antifouling coatings. It's independent verification that robotic cleaning is safe for your paint." },
      { q: "Can you clean steel or aluminium hulls?", a: "Yes. The Keelcrab Pro uses magnetic attachment on ferrous (steel) hulls and vacuum attachment on non-ferrous hulls including aluminium and GRP. We select appropriate brush pressure and head type for each hull material to ensure safe, effective cleaning." },
    ]
  },
  {
    category: "Booking & Service",
    questions: [
      { q: "How do I book a clean or inspection?", a: "Use our online booking forms — 'Book a Clean' or 'Book an Inspection' on the contact page. Tell us your boat length, location, and preferred date, and we'll confirm within 24 hours. Alternatively, call or email us directly." },
      { q: "How long does a clean take?", a: "A typical 12m (39ft) yacht takes about 1 hour. A 16m (52ft) vessel takes approximately 1.5 hours, and an 18m (59ft) vessel around 2 hours. These are estimates — heavily fouled hulls may take longer." },
      { q: "How often should I have my hull cleaned?", a: "According to Keelcrab guidelines, boats stationary in closed waters should be cleaned at a maximum interval of 6 months to prevent heavy fouling taking root. Regular cleaning as part of a maintenance plan removes the first layer of growth before it becomes a breeding ground for mussels and barnacles — reducing the need for expensive extraordinary interventions like haul-outs." },
      { q: "Do I need to be present during the clean?", a: "No. You're welcome to watch, but it's not necessary. Photos and video of your hull are sent directly to your smartphone afterwards, so you can see exactly what was done even if you can't attend." },
      { q: "What do I receive after a clean?", a: "Every clean includes HD video footage of your hull and a digital before/after report delivered to your smartphone. For inspections, you receive a written visual condition report (PDF) with timestamped video and recommendations." },
      { q: "Which marinas do you cover?", a: "We're based in Brixham and cover Brixham Marina, Torquay Marina, and Darthaven Marina in Dartmouth. We can also service vessels on swing moorings and private pontoons across the River Dart." },
      { q: "Can you clean in bad weather?", a: "Light rain is fine — our operator works from the pontoon and the robot is fully submersible. However, strong winds (above Force 5), heavy swell, or thunderstorms may require us to reschedule for safety. If weather affects your booking, we'll contact you to rearrange at the next available slot." },
      { q: "Can you work at night or early morning?", a: "The Keelcrab Pro has built-in LED lighting, so the robot itself works in any light conditions. However, pontoon access and marina regulations typically limit our operating hours to daylight. For urgent or time-sensitive jobs, contact us and we'll do our best to accommodate." },
    ]
  },
  {
    category: "Pricing & Plans",
    questions: [
      { q: "How much does a hull clean cost?", a: "Hull cleaning is £15 per metre of boat length, with a minimum charge of £150. For example, a 12m yacht costs £180, and a 15m vessel costs £225." },
      { q: "How much does an inspection cost?", a: "Visual hull inspections are £10 per metre, with a minimum charge of £100. For example, a 12m yacht costs £120. This is a visual condition report, not a qualified marine survey." },
      { q: "What are the maintenance plan options?", a: "We offer two plans: the Essential Plan (4 cleans per year, 15% discount) and the Premium Plan (6 cleans per year, 20% discount plus one free annual visual inspection). Both include priority scheduling." },
      { q: "Is there a minimum charge?", a: "Yes. The minimum charge for cleaning is £150 (covers vessels up to 10m). The minimum charge for inspection is £100. This ensures every visit is operationally viable." },
    ]
  },
  {
    category: "Maintenance & Aftercare",
    questions: [
      { q: "Can regular cleaning extend the life of my antifouling?", a: "Yes — significantly. Antifouling paint degrades fastest when heavy fouling organisms like barnacles bond to the surface and are then forcibly removed, pulling ablative paint layers away with them. Regular robotic cleaning prevents heavy fouling from establishing in the first place, so your antifouling erodes at its natural, designed rate. Many of our maintenance plan members report extending their re-antifouling interval by a full season." },
      { q: "Does hull cleaning help with my insurance?", a: "It can. Many marine insurers look favourably on documented hull maintenance. Our timestamped HD video reports provide evidence of regular professional cleaning and hull condition monitoring. While policies vary, having a documented maintenance history strengthens your position if you ever need to make a claim." },
      { q: "Do you clean propellers, anodes, or running gear?", a: "Our service focuses exclusively on the hull surface. We do not clean propellers, anodes, rudders, or other underwater running gear — these are outside our scope and may require specialist attention. However, our inspection camera can visually assess the condition of these components and flag any issues in your report." },
      { q: "What should I do after a hull clean to maintain results?", a: "The best thing you can do is sail your boat. Regular movement through the water naturally inhibits early-stage fouling. If your boat sits on a marina berth for extended periods between sails, consider scheduling your next clean before the fouling has time to harden — typically every 6-12 weeks during the growing season (April–October)." },
    ]
  },
  {
    category: "Safety & Environment",
    questions: [
      { q: "Is robotic cleaning safer than using divers?", a: "Yes. Robotic cleaning eliminates the need for commercial dive teams and the associated HSE risks. There are no divers in the water, no heavy lifting equipment, and the operator works safely from the pontoon." },
      { q: "Is your service eco-friendly?", a: "Absolutely. All debris is captured in the Keelcrab Bag and disposed of properly — nothing enters the water during the cleaning process. More importantly, regular robotic cleaning reduces the need for toxic biocide antifouling chemicals. As Keelcrab's manufacturer puts it: 'the biocide is actually replaced by robotic cleaning operations.' This makes our service both green and effective." },
      { q: "Does cleaning affect the marine environment?", a: "Our cleaning process is designed to protect the marine environment. A.N.C.C.P certified brushes ensure no damage to antifouling coatings, while the Keelcrab Bag captures all removed material. Regular hull cleaning also helps prevent the spread of invasive species between harbours — a concern specifically flagged by Dart Harbour authority." },
      { q: "Does hull cleaning help prevent the spread of invasive species?", a: "Yes. Hull fouling is one of the main ways invasive aquatic species are transferred between water bodies. The IMO's 2023 Biofouling Guidelines and the UK's Non-Native Species Secretariat both recommend regular hull cleaning as a key biosecurity measure. By keeping your hull clean, you're actively helping to protect local marine ecosystems." },
    ]
  }
];
---
<ServiceLayout
  title="Frequently Asked Questions"
  description="Everything you need to know about HullSafe's robotic hull cleaning and inspection service. Pricing, technology, booking, and more."
  heroTitle="Frequently Asked Questions"
  heroSubtitle="Everything you need to know about robotic hull cleaning and inspection."
  heroImage="/images/keelcrab/optimised/underwater-keelcrab-wide.jpg"
  heroBadge="Got Questions?"
  ctaText="Still Have Questions? Ask Us"
>

  {faqs.map((category) => (
    <section class="section faq-section">
      <div class="container">
        <h2 class="faq-category">{category.category}</h2>
        <div class="faq-list">
          {category.questions.map((faq) => (
            <details class="faq-item">
              <summary>{faq.q}</summary>
              <div class="faq-answer">
                <p>{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  ))}

</ServiceLayout>

<style>
  .faq-section {
    padding: var(--space-2xl) 0;
  }

  .faq-section:nth-child(odd) {
    background: var(--surface);
  }

  .faq-category {
    font-size: 1.5rem;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--accent);
    display: inline-block;
  }

  .faq-list {
    max-width: 800px;
  }
</style>
